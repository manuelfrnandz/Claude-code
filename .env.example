# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | staging | production
PORT=3001
APP_SECRET_KEY=change-me-minimum-32-characters!!

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Settings → API → service_role key (secret)

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
BULL_REDIS_URL=redis://localhost:6379/1
SESSION_TTL_SECONDS=86400             # 24 hours

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_MS=30000

# ─── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
META_APP_SECRET=
META_VERIFY_TOKEN=your-webhook-verify-token
META_API_VERSION=v19.0
META_GRAPH_URL=https://graph.facebook.com

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000            # 1 minute window
RATE_LIMIT_MAX=60                     # max requests per window per IP

# ─── Admin / Setup ────────────────────────────────────────────────────────────
ADMIN_SECRET=change-me-admin-password

# IPs permitidas para POST /api/v1/setup en producción (comma-separated).
# Dejar vacío para permitir cualquier IP (útil en dev). Ejemplo: 1.2.3.4,5.6.7.8
ALLOWED_SETUP_IPS=

# ─── Worker ───────────────────────────────────────────────────────────────────
# Set DISABLE_WORKER=true to run the HTTP server without the BullMQ worker
# (useful when running the worker as a separate process/dyno)
DISABLE_WORKER=false
WORKER_CONCURRENCY=5

# ─── Dashboard (apps/dashboard/) ──────────────────────────────────────────────
# Generar NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — crear en console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TENANT_ID=               # UUID of the tenant for this dashboard instance
