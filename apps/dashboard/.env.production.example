# NextAuth — generar NEXTAUTH_SECRET con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://TU_DOMINIO_DASHBOARD.railway.app

# Google OAuth — crear en console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API backend en Railway
NEXT_PUBLIC_API_URL=https://claude-code-production-665a.up.railway.app

# ID del tenant creado en Supabase
NEXT_PUBLIC_TENANT_ID=63e9cfd8-7273-4575-81b9-cd968a90eb18

# Admin secret (mismo valor que ADMIN_SECRET en el servicio de API)
NEXT_PUBLIC_ADMIN_SECRET=
